                  <th class='lbl ev lbl-horse-resilience r'>Resilience</th>
                  <td class='var ev var-horse-resilience c'>{{variables.horse_resilience|default}}</td>
                </tr>
                <tr>
                  <th class='lbl ev lbl-horse-quick r'>Quick</th>
                  <td class='var ev var-horse-quick c'>{{variables.horse_quick|default}}</td>
                  <th class='lbl ev lbl-horse-shakes r'>Shakes</th>
                  <td class='var ev var-horse-shakes c'>{% set curr = variables.horse_shakes|default %}{% for i in 1..variables.horse_quick|default %}{% if i <= curr %}<i class='fa-solid fa-square'></i>{% else %}<i class='fa-regular fa-square'></i>{% endif %}{% endfor %}</td>
                  <th class='lbl ev lbl-horse-move r'>Move</th>
                  <td class='var ev var-horse-move c'>{{variables.horse_move|default}}</td>
                </tr>
                <tr>
                  <th class='lbl ev lbl-horse-cunning r'>Cunning</th>
                  <td class='var ev var-horse-cunning c'>{{variables.horse_cunning|default}}</td>
                  <th class='lbl ev lbl-horse-vexes r'>Vexes</th>
                  <td class='var ev var-horse-vexes c'>{% set curr = variables.horse_vexes|default %}{% for i in 1..variables.horse_cunning|default %}{% if i <= curr %}<i class='fa-solid fa-square'></i>{% else %}<i class='fa-regular fa-square'></i>{% endif %}{% endfor %}</td>
                  <th class='lbl ev lbl-horse-fighting r'>Fighting</th>
                  <td class='var ev var-horse-fighting c'>{{variables.horse_fighting|default}}</td>
                </tr>

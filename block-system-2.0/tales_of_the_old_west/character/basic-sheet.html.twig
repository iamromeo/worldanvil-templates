                  <th class='lbl ev lbl-horse-flaws r'>Flaws</th>
                  <td class='var ev var-horse-flaws' colspan=2>{{variables.horse_flaws|default}}</td>
                </tr>
                <tr>
                  <th class='lbl ev lbl-horse-grit r'>Grit</th>

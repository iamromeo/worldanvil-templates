                    <table width="100%">
                        <tr><th class="lbl l">Pension</th><td class="txt r">{{variables.pension|default}}</td></tr>
                        <tr><th class="lbl l">Debt</th><td class="txt r">{{variables.debt|default}}</td></tr>
                        <tr><th class="lbl l">Cash On Hand</th><td class="txt r">{{variables.cash_on_hand|default}}</td></tr>
                        <tr><th class="lbl l">Monthly Ship Payments</th><td class="txt r">{{variables.monthly_ship_payments|default}}</td></tr>
                        <tr><th class="lbl l">Living Cost</th><td class="txt r">{{variables.living_cost|default}}</td></tr>
                    </table>
                </div>
            </div>
             <div class="card my-2 of">
                <div class="card-header head-bar">CAREERS <button class="btn btn-link collapsed" data-toggle="collapse" data-target="#collapseRow1" aria-expanded="true" aria-controls="collapseRow1"><em class="fas fa-angle-down"></em></button></div>

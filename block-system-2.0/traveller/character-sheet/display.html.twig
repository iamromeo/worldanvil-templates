                                <td class="txt l" width=50%>{{ name }}</td>
                                <td class="txt c" width=20%>{{ attribute(variables, 'career_terms' ~ t)|default }}</td>
                                <td class="txt c">{{ attribute(variables, 'career_rank' ~ t)|default }}</td>
                            </tr>

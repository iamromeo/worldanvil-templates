<div class="container-fluid mgt2-sheet">
    <div class="row">
        <div class="col-12 col-md-12 col-lg-12 hidden-xs hidden-sm d-none d-lg-block">
            <div class="card my-2 of">
                <div class="card-header head-bar">Traveller (Mongoose 2nd ed)</div>
            </div>
        </div>
    </div>
    <div class="row">
        <div class="col-12 col-md-12 col-lg-12">
            <div class="card my-2 di">
                <input value="1" {% if variables.usealt|default == 1 %} checked="checked"{% endif %} id="usealt" name="usealt" type="checkbox" /> Use alternate characteristics (save sheet after changing!)
            </div>
        </div>
        <div class="col-12 col-md-12 col-lg-6">
            <div class="card my-2 of">
                <div class="card-header head-bar">BACKGROUND</div>
                <div class="card-body collapse show od">
                    <table width="100%">
                        <tr><th class="lbl l">Name</th><td class="txt r"><input value="{{ variables.name|default }}" required="required" class="form-control" id="name" name="name" placeholder="The name of the character" type="text" /></td></tr>
                        <tr><th class="lbl l">Rads</th><td class="txt r"><input value="{{ variables.rads|default }}" class="form-control" id="rads" name="rads" type="text" /></td></tr>
                        <tr><th class="lbl l">Age</th><td class="txt r"><input value="{{ variables.age|default }}" class="form-control" id="age" name="age" type="text" /></td></tr>
                        <tr><th class="lbl l">Species</th><td class="txt r"><input value="{{ variables.species|default }}" class="form-control" id="species" name="species" placeholder="eg human" type="text" /></td></tr>
                        <tr><th class="lbl l">Species Traits</th><td class="txt r"><input value="{{ variables.species_traits|default }}" class="form-control" id="species_traits" name="species_traits" type="text" /></td></tr>
                        <tr><th class="lbl l">Homeworld</th><td class="txt r"><input value="{{ variables.homeworld|default }}" class="form-control" id="homeworld" name="homeworld" placeholder="eg earth, mars" type="text" /></td></tr>
                    </table>
                </div>
            </div>
            <div class="card my-2 of">
                <div class="card-header head-bar">Study Period</div>
                <div class="card-body collapse show od">
                    <table width="100%">
                        <tr>
                            <th class="lbl l">skill</th>
                            <th class="lbl c" width=20%>weeks/done</th>
                            <th class="lbl c" width=20%>/required</th>
                            <th class="lbl c" width=20%>period done</th>
                        </tr>
                        {% for i in 1..5 %}
                            {% set t = '' %}{% if i > 1 %}{% set t = '_' ~ i %}{% endif %}
                            <tr>
                                <td class="txt l"><input value="{{ attribute(variables, 'train_skill' ~ t)|default }}" class="form-control" id="train_skill{{t}}" name="train_skill{{t}}" type="text" /></td>
                                <td class="txt c"><input value="{{ attribute(variables, 'train_weeks_done' ~ t)|default }}" class="form-control c" id="train_weeks_done{{t}}" name="train_weeks_done{{t}}" type="text" /></td>
                                <td class="txt c"><input value="{{ attribute(variables, 'train_weeks_required' ~ t)|default }}" class="form-control c" id="train_weeks_required{{t}}" name="train_weeks_required{{t}}" type="text" /></td>
                                <td class="txt c"><input value="{{ attribute(variables, 'train_periods_done' ~ t)|default }}" class="form-control c" id="train_periods_done{{t}}" name="train_periods_done{{t}}" type="text" /></td>
                            </tr>
                        {% endfor %}
                    </table>
                </div>
            </div>
        </div>
        <div class="col-12 col-md-12 col-lg-6">
            <div class="card my-2 of">
                <div class="card-header head-bar">FINANCES</div>
                <div class="card-body collapse show od">
                    <table width="100%">
                        <tr><th class="lbl l">Pension</th><td class="txt r"><input value="{{ variables.pension|default }}" class="form-control" id="pension" name="pension" type="text" /></td></tr>
                        <tr><th class="lbl l">Debt</th><td class="txt r"><input value="{{ variables.debt|default }}" class="form-control" id="debt" name="debt" type="text" /></td></tr>
                        <tr><th class="lbl l">Cash On Hand</th><td class="txt r"><input value="{{ variables.cash_on_hand|default }}" class="form-control" id="cash_on_hand" name="cash_on_hand" type="text" /></td></tr>
                        <tr><th class="lbl l">Monthly Ship Payments</th><td class="txt r"><input value="{{ variables.monthly_ship_payments|default }}" class="form-control" id="monthly_ship_payments" name="monthly_ship_payments" type="text" /></td></tr>

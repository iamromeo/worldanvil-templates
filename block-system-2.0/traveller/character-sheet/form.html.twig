{% macro genBonus(ch) %}
{% set b = 0 %}
{% if ch == 0 %}{% set b = '-3' %}{% endif %}
{% if ch > 0 %}{% set b = '-2' %}{% endif %}
{% if ch > 2 %}{% set b = '-1' %}{% endif %}
{% if ch > 5 %}{% set b = '+0' %}{% endif %}
{% if ch > 8 %}{% set b = '+1' %}{% endif %}
{% if ch > 11 %}{% set b = '+2' %}{% endif %}
{% if ch > 14 %}{% set b = '+3' %}{% endif %}
{{b}}{% endmacro genBonus %}
{# --------------------------------------- #}
{% macro genSkill(id, name, val, dn) %}{% set eo = "od" %}{% if id is even %}{% set eo = "ev" %}{% endif %}{% if name == '' %}{% set name = dn %}{% endif %}<tr>
    <th class="lbl l"><input value="{{ name }}" class="form-control" id="skill_{{id}}" name="skill_{{id}}" type="text" /></th>
    <td class="txt c {{eo}}" width="20%"><input value="{{ val }}" class="form-control c" id="skill_value_{{id}}" name="skill_value_{{id}}" type="text" /></td>
</tr>{% endmacro genSkill %}
{# --------------------------------------- #}
{% macro genArmour(id, name, rad, prot, kg, options) %}{% set eo = "od" %}{% if id is even %}{% set eo = "ev" %}{% endif %}<tr>
    <td class="lbl l"><input value="{{ name }}" class="form-control" id="armour_type_{{id}}" name="armour_type_{{id}}" type="text" /></td>
    <td class="txt c {{eo}}"><input value="{{ rad }}" class="form-control c" id="armour_rad_{{id}}" name="armour_rad_{{id}}" type="text" /></td>
    <td class="txt c {{eo}}"><input value="{{ prot }}" class="form-control c" id="armour_protection_{{id}}" name="armour_protection_{{id}}" type="text" /></td>
    <td class="txt c {{eo}}"><input value="{{ kg }}" class="form-control c" id="armour_kg_{{id}}" name="armour_kg_{{id}}" type="text" /></td>
    <td class="txt l {{eo}}"><input value="{{ options }}" class="form-control" id="armour_options_{{id}}" name="armour_options_{{id}}" type="text" /></td>
</tr>{% endmacro genArmour %}
{# --------------------------------------- #}
{% macro genWeapon(id, name, tl, range, dmg, kg, mag, traits) %}{% set eo = "od" %}{% if id is even %}{% set eo = "ev" %}{% endif %}<tr>
    <td class="lbl l"><input value="{{ name }}" class="form-control" id="weapon_{{id}}" name="weapon_{{id}}" type="text" /></td>
    <td class="txt c {{eo}}"><input value="{{ tl }}" class="form-control c" id="weapon_tl_{{id}}" name="weapon_tl_{{id}}" type="text" /></td>
    <td class="txt c {{eo}}"><input value="{{ range }}" class="form-control c" id="weapon_range_{{id}}" name="weapon_range_{{id}}" type="text" /></td>
    <td class="txt c {{eo}}"><input value="{{ dmg }}" class="form-control c" id="weapon_dmg_{{id}}" name="weapon_dmg_{{id}}" type="text" /></td>
    <td class="txt c {{eo}}"><input value="{{ kg }}" class="form-control c" id="weapon_kg_{{id}}" name="weapon_kg_{{id}}" type="text" /></td>
    <td class="txt c {{eo}}"><input value="{{ mag }}" class="form-control c" id="weapon_magazine_{{id}}" name="weapon_magazine_{{id}}" type="text" /></td>
    <td class="txt l {{eo}}"><input value="{{ traits }}" class="form-control" id="weapon_traits_{{id}}" name="weapon_traits_{{id}}" type="text" /></td>
</tr>{% endmacro genWeapon %}
{# --------------------------------------- #}
{% macro genAugment(id, name, tl, improv) %}{% set eo = "od" %}{% if id is even %}{% set eo = "ev" %}{% endif %}<tr>
    <td class="lbl l"><input value="{{ name }}" class="form-control" id="augment_type_{{id}}" name="augment_type_{{id}}" type="text" /></td>
    <td class="txt c {{eo}}"><input value="{{ tl }}" class="form-control c" id="augment_tl_{{id}}" name="augment_tl_{{id}}" type="text" /></td>
    <td class="txt l {{eo}}"><input value="{{ improv }}" class="form-control" id="augment_improvement_{{id}}" name="augment_improvement_{{id}}" type="text" /></td>
</tr>{% endmacro genAugment %}
